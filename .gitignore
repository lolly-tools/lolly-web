# Vendored Adobe TrustMark ONNX decoder models (tens of MB each) — downloaded
# by scripts/fetch-trustmark-models.ts (Andy-run; needs network), never
# generated by a normal build. Not committed for the same reason node_modules/
# isn't: too large for git, and re-fetchable from a documented source. The web
# shell fetches them once at runtime and caches the bytes in IndexedDB (see
# shells/web/src/lib/trustmark.ts), so end users never touch this directory.
public/models/
# Same story for the onnxruntime-web wasm/mjs runtime the models run on —
# copied from node_modules/onnxruntime-web/dist/ per fetch-trustmark-models.ts
# (trustmark.ts sets ort.env.wasm.wasmPaths = '/ort/').
public/ort/
